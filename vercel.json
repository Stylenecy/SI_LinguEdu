{
  "buildCommand": "composer install --no-dev --optimize-autoloader && npm install && npm run build",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "public/index.php": {
      "runtime": "vercel-php@8.2",
      "includeFiles": [
        "app/**",
        "bootstrap/**",
        "config/**",
        "database/**",
        "public/**",
        "resources/**",
        "routes/**",
        "storage/**",
        "vendor/**"
      ]
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/storage/(.*)", "dest": "/public/storage/$1" },
    { "src": "/(.*)", "dest": "/public/index.php" }
  ]
}
